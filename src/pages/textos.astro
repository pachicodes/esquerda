---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostList from '../components/PostList.astro';
import { getPublishedPosts } from '../lib/posts';

const title = 'Todos os textos';
const description =
  'Todos os textos publicados em Leitura do Mundo, com filtro por categoria.';

const posts = await getPublishedPosts();
---

<BaseLayout title={title} description={description}>
  <header class="home-intro">
    <h1>{title}</h1>
    <p class="home-tagline">
      Leia os textos publicados e filtre por tema quando quiser encontrar um
      assunto específico.
    </p>
  </header>

  <section class="home-posts" aria-labelledby="texts-heading">
    <h2 id="texts-heading">Arquivo de textos</h2>
    <PostList posts={posts} showFilter />
  </section>
</BaseLayout>
