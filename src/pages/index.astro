---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostList from '../components/PostList.astro';
import { getPublishedPosts } from '../lib/posts';
import { withBase } from '../lib/paths';

const title = 'Leitura do Mundo';
const description =
  'Textos sobre poder, linguagem, política e tecnologia para quem cansou de ser deixada do lado de fora da conversa.';
const tagline =
  'Textos sobre poder, linguagem, política e tecnologia para quem cansou de ser deixada do lado de fora da conversa.';

const posts = await getPublishedPosts();
const recentPosts = posts.slice(0, 5);
---

<BaseLayout title={title} description={description}>
  <header class="home-intro">
    <h1>{title}</h1>
    <p class="home-tagline">{tagline}</p>
    <p>
      Este blog reúne textos para quem quer entender o mundo sem depender de
      linguagem acadêmica, jurídica ou tecnocrática. Aqui, poder, política e
      tecnologia são explicados com clareza e sem condescendência.
    </p>
    <p>
      <a href={withBase('sobre')}>Sobre o blog</a>
    </p>
  </header>

  <section class="home-posts" aria-labelledby="posts-heading">
    <h2 id="posts-heading">Últimos textos</h2>
    <PostList posts={recentPosts} />
    {posts.length > 0 && (
      <p class="home-posts__more">
        <a href={withBase('textos')}>Ver todos os textos</a>
      </p>
    )}
  </section>

  <aside class="home-epigraph" aria-label="Inspiração do nome">
    <blockquote class="epigraph">
      <p>“A leitura do mundo precede a leitura da palavra.”</p>
      <cite>Paulo Freire</cite>
    </blockquote>
    <p class="epigraph__note">
      O nome deste blog nasce dessa ideia. <a href={withBase('sobre')}>Conheça a origem</a>.
    </p>
  </aside>
</BaseLayout>
