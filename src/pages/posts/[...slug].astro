---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { formatPostDate, postDateIso } from '../../lib/dates';
import { withBase } from '../../lib/paths';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => data.published);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const dateFormatted = formatPostDate(post.data.date);
const dateIso = postDateIso(post.data.date);
---

<BaseLayout title={post.data.title} description={post.data.description}>
  <article class="post-article">
    <header class="post-article__header">
      <h1>{post.data.title}</h1>
      <p class="post-article__meta">
        <time datetime={dateIso}>{dateFormatted}</time>
        <span class="post-article__separator" aria-hidden="true">·</span>
        <span class="post-article__category">{post.data.category}</span>
        <span class="post-article__separator" aria-hidden="true">·</span>
        <span>{post.data.readingTime}</span>
      </p>
      <p class="post-article__description">{post.data.description}</p>
    </header>

    <div class="post-content">
      <Content />
    </div>
  </article>

  <p class="post-back">
    <a href={withBase()}>← Voltar para a página inicial</a>
  </p>
</BaseLayout>
